MONGODB_URI=

# Plan Pricing and Limits
PLAN_BASIS_PRICE=1
PLAN_BASIS_MINUTES=60
PLAN_BASIS_PPM=0.10

PLAN_PRO_PRICE=5
PLAN_PRO_MINUTES=1440
PLAN_PRO_PPM=0.05

PLAN_MAX_PRICE=20
PLAN_MAX_MINUTES=43200
PLAN_MAX_PPM=0.01

# Cloudflare R2 Credentials for Telemetry Storage
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="spaceborn-telemetry"
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://pub-xxxxxx.r2.dev"