# ── Engine ────────────────────────────────────────────────────────────
Options -Indexes
ServerSignature Off
RewriteEngine On

# ── HTTPS redirect ────────────────────────────────────────────────────
RewriteCond %{HTTP:X-Forwarded-Proto} =http
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Hide PHP and server version ───────────────────────────────────────
<IfModule mod_headers.c>
    Header unset X-Powered-By
    Header always unset X-Powered-By
    Header unset Server
</IfModule>

# ── Security headers ──────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Force HTTPS for 1 year, include subdomains
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Prevent clickjacking — no iframes from other sites
    Header always set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Control referrer info sent to external sites
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Restrict browser feature access
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self)"

    # CSP — covers WebGL, Three.js, Razorpay, Google Auth, Cloudflare R2
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://checkout.razorpay.com https://cdn.razorpay.com https://accounts.google.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' data: blob:; connect-src 'self' https://api.razorpay.com https://lumberjack.razorpay.com https://accounts.google.com wss: https://*.r2.cloudflarestorage.com https://*.r2.dev; frame-src https://checkout.razorpay.com https://api.razorpay.com https://accounts.google.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self';"
</IfModule>

# ── Block access to sensitive files ───────────────────────────────────
<FilesMatch "\.(env|env\.example|lock|md|log|sh|sql|yml|yaml|DS_Store)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# ── Block access to hidden files/directories (.git, .env etc.) ────────
RewriteRule ^\.(?!well-known) - [F,L]

# ── Block access to composer files ───────────────────────────────────
RewriteRule ^(vendor|composer\.(json|lock))(/|$) - [F,L]

# ── Block web access to seed/admin-only scripts ───────────────────────
<Files "seed_subscriptions.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>